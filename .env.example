# ---------------------------------------------------------------------------
# Bridgelet Core - environment configuration
#
# The repo ships with NO .env.example, so this is reconstructed directly from
# what scripts/deploy-testnet.sh actually requires (via its `: "${VAR:?...}"`
# guards) plus the contract IDs it writes out on success. Fill in real values
# before running any deploy or SDK integration against these contracts.
# ---------------------------------------------------------------------------

# --- Required by scripts/deploy-testnet.sh (deployment will abort without these) ---

# Deployer/admin Stellar secret key (S... format). Pays fees and signs the
# `initialize` calls. NEVER commit a real value here.
SIGNER_SECRET_KEY=

# Ed25519 PUBLIC key that SweepController will verify sweep-authorization
# signatures against (contracts/sweep_controller/src/authorization.rs).
# This is the counterpart to whatever private key your off-chain SDK/relayer
# holds to sign sweep messages.
# run the ./target/release/sweep-signer pubkey --signer-seed-hex d06108fa393494747d37380f0b8a044d641c0e8c325f622fd3dacaff7376febd
AUTHORIZED_SIGNER_PUBLIC_KEY=

# Organization's fallback wallet. Used per-account as `recovery_address` at
# EphemeralAccount::initialize() - funds return here if an account expires
# unswept.
RECOVERY_ADDRESS=

# Address that calls SweepController::initialize() as `creator` (must match
# the account backing SIGNER_SECRET_KEY, or that account must be able to
# authorize on its behalf).
CREATOR_ADDRESS=

# --- Populated by scripts/deploy-testnet.sh after a successful deploy ---
# (also duplicated into deployment-artifacts/contract-ids.txt as CI artifacts)

EPHEMERAL_ACCOUNT_CONTRACT_ID=CDRESWC6IADJ4V363TQBCDMVG24A56N6LTTTKMD6EV4NMD3K43SKDFUR
SWEEP_CONTROLLER_CONTRACT_ID=

# --- NOT currently produced by any script, but needed if you use these contracts ---

# reserve_contract is a workspace member and is built by scripts/build.sh, but
# scripts/deploy-testnet.sh never deploys it and never sets this variable
# (it references $RESERVE_CONTRACT_ID in its output without assigning it -
# see README "Build & Deploy" section). Deploy it manually and set this
# yourself until that script is fixed:
RESERVE_CONTRACT_CONTRACT_ID=

# account_factory is a workspace member but is not built OR deployed by any
# existing script. Build/deploy it manually if you intend to batch-create
# ephemeral accounts, then record its ID here:
ACCOUNT_FACTORY_CONTRACT_ID=

# --- Network config (hardcoded in scripts/deploy-testnet.sh today, but real
#     SDK/client code will need these explicitly - not currently documented
#     anywhere as env vars) ---

STELLAR_NETWORK=testnet
STELLAR_NETWORK_PASSPHRASE="Test SDF Network ; September 2015"
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org
STELLAR_SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
